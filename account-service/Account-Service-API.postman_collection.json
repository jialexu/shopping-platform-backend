{
  "info": {
    "name": "Account Service API",
    "description": "Collection for testing Account Service endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"username\": \"john_doe\",\n  \"password\": \"SecurePass123!\",\n  \"shippingAddress\": \"123 Main St, City, State 12345\",\n  \"billingAddress\": \"123 Main St, City, State 12345\",\n  \"paymentMethod\": \"Credit Card\"\n}"
        },
        "url": {
          "raw": "http://localhost:9001/api/accounts",
          "protocol": "http",
          "host": ["localhost"],
          "port": "9001",
          "path": ["api", "accounts"]
        }
      }
    },
    {
      "name": "Get User by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:9001/api/accounts/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "9001",
          "path": ["api", "accounts", "1"]
        }
      }
    },
    {
      "name": "Update User",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"john_doe_updated\",\n  \"shippingAddress\": \"456 New St, City, State 67890\",\n  \"billingAddress\": \"456 New St, City, State 67890\",\n  \"paymentMethod\": \"Debit Card\"\n}"
        },
        "url": {
          "raw": "http://localhost:9001/api/accounts/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "9001",
          "path": ["api", "accounts", "1"]
        }
      }
    },
    {
      "name": "Internal - Get Auth Details",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\"\n}"
        },
        "url": {
          "raw": "http://localhost:9001/api/accounts/_internal/auth",
          "protocol": "http",
          "host": ["localhost"],
          "port": "9001",
          "path": ["api", "accounts", "_internal", "auth"]
        }
      }
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:9001/actuator/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "9001",
          "path": ["actuator", "health"]
        }
      }
    }
  ]
}
